<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.admission.mapper.CandidateProfileMapper">

    <!-- 结果映射：处理数据库下划线字段与Java驼峰属性的对应关系 -->
    <resultMap id="CandidateResultMap" type="com.admission.entity.CandidateProfile">
        <id property="examId" column="exam_id"/>
        <result property="name" column="name"/>
        <result property="gender" column="gender"/>
        <result property="age" column="age"/>
        <result property="politicalStatus" column="political_status"/>
        <result property="isFreshGraduate" column="is_fresh_graduate"/>
        <result property="education" column="education"/>
        <result property="origin" column="origin"/>
        <result property="targetMajor" column="target_major"/>
        <result property="category" column="category"/>
    </resultMap>

    <!-- 查询所有考生 -->
    <select id="findAll" resultMap="CandidateResultMap">
        SELECT * FROM candidate_profile
    </select>

    <!-- 根据考号查询 -->
    <select id="findByExamId" resultMap="CandidateResultMap">
        SELECT * FROM candidate_profile WHERE exam_id = #{examId}
    </select>

    <!-- 根据报考专业查询 -->
    <select id="findByMajor" resultMap="CandidateResultMap">
        SELECT * FROM candidate_profile WHERE target_major = #{targetMajor}
    </select>

    <!-- 新增考生 -->
    <insert id="insert">
        INSERT INTO candidate_profile (exam_id, name, gender, age, political_status, 
                                       is_fresh_graduate, education, origin, target_major, category)
        VALUES (#{examId}, #{name}, #{gender}, #{age}, #{politicalStatus}, 
                #{isFreshGraduate}, #{education}, #{origin}, #{targetMajor}, #{category})
    </insert>

    <!-- 更新考生信息 -->
    <update id="update">
        UPDATE candidate_profile
        SET name = #{name},
            gender = #{gender},
            age = #{age},
            political_status = #{politicalStatus},
            is_fresh_graduate = #{isFreshGraduate},
            education = #{education},
            origin = #{origin},
            target_major = #{targetMajor},
            category = #{category}
        WHERE exam_id = #{examId}
    </update>

    <!-- 删除考生 -->
    <delete id="deleteByExamId">
        DELETE FROM candidate_profile WHERE exam_id = #{examId}
    </delete>

</mapper>