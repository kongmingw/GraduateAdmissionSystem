<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.admission.mapper.ScoreLineMapper">

    <resultMap id="ScoreLineMap" type="com.admission.entity.ScoreLine">
        <id property="id" column="id"/>
        <result property="year" column="year"/>
        <result property="politicsLine" column="politics_line"/>
        <result property="foreignLangLine" column="foreign_lang_line"/>
        <result property="majorBasisLine" column="major_basis_line"/>
        <result property="totalFirstLine" column="total_first_line"/>
        <result property="admissionTotalLine" column="admission_total_line"/>
    </resultMap>

    <select id="findAll" resultMap="ScoreLineMap">
        SELECT * FROM score_line ORDER BY year DESC
    </select>

    <select id="findById" resultMap="ScoreLineMap">
        SELECT * FROM score_line WHERE id = #{id}
    </select>

    <select id="findByYear" resultMap="ScoreLineMap">
        SELECT * FROM score_line WHERE year = #{year}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO score_line (year, politics_line, foreign_lang_line, major_basis_line,
                                total_first_line, admission_total_line)
        VALUES (#{year}, #{politicsLine}, #{foreignLangLine}, #{majorBasisLine},
                #{totalFirstLine}, #{admissionTotalLine})
    </insert>

    <update id="update">
        UPDATE score_line
        SET year = #{year},
            politics_line = #{politicsLine},
            foreign_lang_line = #{foreignLangLine},
            major_basis_line = #{majorBasisLine},
            total_first_line = #{totalFirstLine},
            admission_total_line = #{admissionTotalLine}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM score_line WHERE id = #{id}
    </delete>

</mapper>
